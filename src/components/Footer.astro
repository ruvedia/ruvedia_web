---
// Componente Footer premium para Ruvedia.com
const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400 pt-20 pb-10 border-t border-slate-900" id="footer">
  <div class="max-w-7xl mx-auto px-6 z-10 relative">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 pb-16 border-b border-slate-900">
      
      <!-- Column 1: Brand & Logo -->
      <div class="lg:col-span-4 space-y-6">
        <div class="flex items-center gap-2">
          <span class="text-xl font-extrabold text-white font-mono tracking-tight">
            Ruvedia<span class="text-blue-500">.com</span>
          </span>
        </div>
        <p class="text-sm text-slate-400 leading-relaxed max-w-sm font-sans">
          Estudio de diseño y desarrollo web de alto rendimiento. Creamos páginas extraordinarias, rápidas y seguras que convierten visitas en clientes reales.
        </p>
        <!-- Social Links -->
        <div class="flex gap-4">
          <a href="#" class="hover:text-white transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162 0 3.403 2.759 6.162 6.162 6.162 3.403 0 6.162-2.759 6.162-6.162 0-3.403-2.759-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
            </svg>
          </a>
          <a href="#" class="hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Services -->
      <div class="lg:col-span-2 space-y-4">
        <h3 class="text-xs font-bold text-white uppercase tracking-wider font-mono">Servicios</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/precios" class="hover:text-white transition-colors">Landing Pages</a></li>
          <li><a href="/precios" class="hover:text-white transition-colors">Webs Corporativas</a></li>
          <li><a href="/precios" class="hover:text-white transition-colors">Tiendas Online</a></li>
          <li><a href="/metodo" class="hover:text-white transition-colors">Optimización de Velocidad</a></li>
        </ul>
      </div>

      <!-- Column 3: Navigation / Agency -->
      <div class="lg:col-span-2 space-y-4">
        <h3 class="text-xs font-bold text-white uppercase tracking-wider font-mono">Estudio</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/portfolio" class="hover:text-white transition-colors">Portafolio</a></li>
          <li><a href="/metodo" class="hover:text-white transition-colors">Nuestro Método</a></li>
          <li><a href="/precios" class="hover:text-white transition-colors">Precios y Planes</a></li>
          <li><a href="/contacto" class="hover:text-white transition-colors">Solicitar Presupuesto</a></li>
        </ul>
      </div>

      <!-- Column 4: Contact / Office Hours -->
      <div class="lg:col-span-4 space-y-4">
        <h3 class="text-xs font-bold text-white uppercase tracking-wider font-mono">Contacto</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:ruvedia@hotmail.com" class="hover:text-white transition-colors">ruvedia@hotmail.com</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Lunes a Viernes: 9:00 - 18:00</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
            <span class="text-xs text-slate-400">Soporte técnico activo en Cloudflare</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom Row: Copyright & Legal links -->
    <div class="pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-slate-400">
      <div>
        &copy; {year} Ruvedia. Todos los derechos reservados.
      </div>
      <div class="flex gap-6">
        <a href="/aviso-legal" class="text-slate-400 hover:text-slate-200 transition-colors">Aviso Legal</a>
        <a href="/politica-de-privacidad" class="text-slate-400 hover:text-slate-200 transition-colors">Privacidad</a>
        <a href="/politica-de-privacidad#cookies" class="text-slate-400 hover:text-slate-200 transition-colors">Cookies</a>
      </div>
    </div>

  </div>
</footer>
