---

---

<section
  class="relative py-24 bg-slate-50/80 overflow-hidden border-t border-slate-100"
  id="precios"
>
  <!-- Subtle decorative grid background -->
  <div
    class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_100%,#000_70%,transparent_100%)] pointer-events-none z-0"
  >
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span
        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-100 mb-6 shadow-sm"
      >
        Tarifas Transparentes
      </span>
      <h2
        class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-950 mb-6 leading-tight"
      >
        Planes web adaptados <span
          class="bg-gradient-to-r from-blue-600 via-indigo-600 to-indigo-500 bg-clip-text text-transparent"
          >a tu negocio</span
        >
      </h2>
      <p class="text-base text-slate-600 leading-relaxed max-w-2xl mx-auto">
        Sin tarifas ocultas ni sorpresas de última hora. Elige el plan que mejor
        se adapte a tus necesidades actuales y empieza a captar clientes en
        internet.
      </p>
    </div>

    <!-- Pricing Cards Grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch"
    >
      <!-- Plan 1: Landing Page -->
      <div
        class="relative bg-white border border-slate-200/60 rounded-3xl p-8 hover:shadow-xl hover:border-blue-500/20 transition-all duration-300 flex flex-col justify-between group"
      >
        <div>
          <!-- Plan header -->
          <div class="mb-6">
            <span
              class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-2"
              >Landing Page / One Page</span
            >
            <div class="flex items-baseline gap-2 text-slate-950 mb-3">
              <span class="text-sm font-semibold text-slate-500">desde</span>
              <span class="text-xl font-medium line-through text-slate-400">249€</span>
              <span class="text-4xl font-extrabold tracking-tight">149€</span>
            </div>
            <p class="text-xs text-slate-500">
              Perfecto para campañas de anuncios y lanzamiento rápido de un
              único servicio o producto.
            </p>
          </div>

          <div class="h-px bg-slate-200/80 my-6"></div>

          <!-- Plan features -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Diseño único responsive premium</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Optimización SEO en página básica</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Velocidad de carga optimizada (PageSpeed 95+)</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Integración de chat de WhatsApp directo</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Formulario de contacto seguro</span>
            </li>
          </ul>
        </div>

        <!-- CTA Link -->
        <a
          href="/contacto"
          id="pricing-plan-landing"
          class="w-full inline-flex items-center justify-center py-3 rounded-full text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-blue-600 hover:text-white transition-all duration-300 focus:outline-none"
        >
          Elegir Plan Landing
        </a>
      </div>

      <!-- Plan 2: Web Profesional (Recomendado) -->
      <div
        class="relative bg-white border-2 border-blue-600 rounded-3xl p-8 shadow-xl shadow-blue-500/5 hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-300 flex flex-col justify-between group"
      >
        <!-- Floating popular badge -->
        <div
          class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-blue-600 text-white text-[9px] font-extrabold uppercase tracking-widest px-3.5 py-1 rounded-full shadow-md"
        >
          El Más Popular
        </div>

        <div>
          <!-- Plan header -->
          <div class="mb-6 mt-2">
            <span
              class="text-[10px] font-bold text-blue-600 uppercase tracking-widest block mb-2"
              >Web Corporativa</span
            >
            <div class="flex items-baseline gap-2 text-slate-950 mb-3">
              <span class="text-sm font-semibold text-slate-500">desde</span>
              <span class="text-xl font-medium line-through text-slate-400">499€</span>
              <span class="text-4xl font-extrabold tracking-tight">299€</span>
            </div>
            <p class="text-xs text-slate-500">
              Perfecto para pymes, profesionales y marcas que quieren
              posicionarse como referentes.
            </p>
          </div>

          <div class="h-px bg-slate-150 my-6"></div>

          <!-- Plan features -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-semibold text-slate-900"
                >Todo lo del plan Landing Page</span
              >
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Hasta 5 secciones internas personalizadas</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Blog autogestionable integrado</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Alta en Google Analytics</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Soporte continuo</span>
            </li>
          </ul>
        </div>

        <!-- CTA Link -->
        <a
          href="/contacto"
          id="pricing-plan-corporativa"
          class="w-full inline-flex items-center justify-center py-3 rounded-full text-xs font-semibold text-white bg-blue-600 hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-500/20 transition-all duration-300 focus:outline-none"
        >
          Elegir Plan Corporativo
        </a>
      </div>

      <!-- Plan 3: E-commerce -->
      <div
        class="relative bg-white border border-slate-200/60 rounded-3xl p-8 hover:shadow-xl hover:border-blue-500/20 transition-all duration-300 flex flex-col justify-between group"
      >
        <div>
          <!-- Plan header -->
          <div class="mb-6">
            <span
              class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block mb-2"
              >Tienda Online</span
            >
            <div class="flex items-baseline gap-2 text-slate-950 mb-3">
              <span class="text-sm font-semibold text-slate-500">desde</span>
              <span class="text-xl font-medium line-through text-slate-400">799€</span>
              <span class="text-4xl font-extrabold tracking-tight">599€</span>
            </div>
            <p class="text-xs text-slate-500">
              Diseñado para comercios y marcas que quieren empezar a vender
              online sus productos físicos o digitales.
            </p>
          </div>

          <div class="h-px bg-slate-200/80 my-6"></div>

          <!-- Plan features -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-semibold text-slate-900"
                >Todo lo del plan Web Profesional</span
              >
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Pasarela de pago segura (Stripe, Bizum, Paypal)</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Subida inicial de hasta 50 productos</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Panel de pedidos y gestión de stock simplificado</span>
            </li>
            <li class="flex items-start gap-3 text-xs text-slate-700">
              <svg
                class="w-4 h-4 text-blue-600 shrink-0 mt-0.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Formación continua</span>
            </li>
          </ul>
        </div>

        <!-- CTA Link -->
        <a
          href="/contacto"
          id="pricing-plan-tienda"
          class="w-full inline-flex items-center justify-center py-3 rounded-full text-xs font-semibold text-slate-700 bg-slate-100 hover:bg-blue-600 hover:text-white transition-all duration-300 focus:outline-none"
        >
          Elegir Plan Tienda
        </a>
      </div>
    </div>
  </div>
</section>
