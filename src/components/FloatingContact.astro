---
---
<!-- Container for Floating Contact Widget -->
<div class="fixed bottom-6 right-6 z-[90] flex flex-col gap-3 items-end">
  
  <!-- Popover menu options (initially hidden) -->
  <div 
    id="contact-options-menu" 
    class="bg-slate-950/95 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl p-4 w-56 transform translate-y-4 opacity-0 pointer-events-none transition-all duration-300 flex flex-col gap-2.5 mb-1"
  >
    <span class="text-white text-[11px] font-bold uppercase tracking-wider text-slate-400 px-1">¿Cómo prefieres hablar?</span>
    
    <!-- Option 1: WhatsApp -->
    <a 
      href="https://wa.me/34622324177" 
      target="_blank" 
      rel="noopener noreferrer" 
      class="flex items-center gap-2.5 p-2 rounded-xl bg-white/5 hover:bg-white/10 text-white text-xs font-semibold transition-all border border-white/5"
    >
      <div class="w-7 h-7 rounded-lg bg-emerald-500/20 text-emerald-400 flex items-center justify-center shrink-0">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
          <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
        </svg>
      </div>
      <span>WhatsApp Chat</span>
    </a>

    <!-- Option 2: Phone Call -->
    <a 
      href="tel:+34622324177" 
      class="flex items-center gap-2.5 p-2 rounded-xl bg-white/5 hover:bg-white/10 text-white text-xs font-semibold transition-all border border-white/5"
    >
      <div class="w-7 h-7 rounded-lg bg-blue-500/20 text-blue-400 flex items-center justify-center shrink-0">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </div>
      <span>Llamada Directa</span>
    </a>

    <!-- Option 3: Email -->
    <a 
      href="mailto:contacto@ruvedia.com" 
      class="flex items-center gap-2.5 p-2 rounded-xl bg-white/5 hover:bg-white/10 text-white text-xs font-semibold transition-all border border-white/5"
    >
      <div class="w-7 h-7 rounded-lg bg-indigo-500/20 text-indigo-400 flex items-center justify-center shrink-0">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <span>Correo Electrónico</span>
    </a>
  </div>

  <!-- Multi-Contact Toggle Button (Llamada, Correo o WhatsApp menu) -->
  <button 
    id="contact-options-btn" 
    class="w-11 h-11 rounded-full bg-blue-600 hover:bg-blue-500 text-white flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-all duration-300 cursor-pointer focus:outline-none relative group"
    aria-label="Opciones de contacto"
  >
    <!-- Toggle active/inactive icon state -->
    <svg id="contact-icon-open" class="w-5.5 h-5.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <svg id="contact-icon-close" class="w-5 h-5 hidden transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
    
    <!-- Tooltip -->
    <span class="absolute right-14 bg-slate-950 text-white text-[10px] font-bold px-2 py-1 rounded shadow-md opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">Contacto rápido</span>
  </button>

  <!-- Direct WhatsApp Floating Button -->
  <a 
    href="https://wa.me/34622324177"  
    target="_blank" 
    rel="noopener noreferrer" 
    class="w-11 h-11 rounded-full bg-[#25D366] hover:bg-[#20ba5a] text-white flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-all duration-300 cursor-pointer relative group"
    aria-label="Chat directo de WhatsApp"
  >
    <!-- WhatsApp SVG -->
    <svg class="w-5.5 h-5.5" fill="currentColor" viewBox="0 0 16 16">
      <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
    </svg>
    
    <!-- Tooltip -->
    <span class="absolute right-14 bg-slate-950 text-white text-[10px] font-bold px-2 py-1 rounded shadow-md opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">Escribir por WhatsApp</span>
  </a>

</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const contactBtn = document.getElementById("contact-options-btn");
    const contactMenu = document.getElementById("contact-options-menu");
    const iconOpen = document.getElementById("contact-icon-open");
    const iconClose = document.getElementById("contact-icon-close");

    if (!contactBtn || !contactMenu || !iconOpen || !iconClose) return;

    let isMenuOpen = false;

    contactBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        contactMenu.classList.remove("translate-y-4", "opacity-0", "pointer-events-none");
        iconOpen.classList.add("hidden");
        iconClose.classList.remove("hidden");
      } else {
        contactMenu.classList.add("translate-y-4", "opacity-0", "pointer-events-none");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
      }
    });

    // Close menu when clicking outside
    document.addEventListener("click", () => {
      if (isMenuOpen) {
        isMenuOpen = false;
        contactMenu.classList.add("translate-y-4", "opacity-0", "pointer-events-none");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
      }
    });
  });
</script>
