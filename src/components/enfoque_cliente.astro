---
---

<section class="relative py-24 bg-slate-50/80 overflow-hidden border-t border-slate-100" id="metodo">
  <!-- Subtle background grid -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-70 pointer-events-none z-0"></div>
  
  <!-- Background Image with opacity overlay -->
  <div 
    class="absolute inset-0 bg-cover bg-center opacity-[0.12] pointer-events-none z-0" 
    style="background-image: url('/enfoque-bg.webp');"
  >
  </div>
  <!-- Soft slate-50 overlay to ensure high contrast/legibility for text -->
  <div class="absolute inset-0 bg-gradient-to-b from-slate-50/40 via-slate-50/80 to-slate-50 pointer-events-none z-0"></div>

  <!-- Content container with relative positioning and z-index to sit on top of background -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    
    <!-- Left Column: Context & Philosophy -->
    <div class="lg:col-span-6 flex flex-col items-start text-left">
      <!-- Badge -->
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-100 mb-6 shadow-sm">
        Enfoque en el Cliente
      </span>

      <!-- Title -->
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-950 mb-6 leading-tight">
        No diseñamos para nosotros, diseñamos para <span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">tus clientes</span>
      </h2>

      <!-- Description -->
      <p class="text-base text-slate-600 mb-8 leading-relaxed">
        El diseño de tu página web no solo debe ser bonito, debe dar resultados. Antes de escribir una sola línea de código, estudiamos tu modelo de negocio, analizamos a tu cliente ideal y definimos la mejor estrategia para convertir visitas en clientes recurrentes.
      </p>

      <!-- Key Pillars -->
      <div class="space-y-6 w-full">
        <!-- Pillar 1 -->
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center text-blue-600 shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-slate-950 text-base mb-1">Análisis Estratégico</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Estudiamos tus objetivos, tu competencia y tu mercado para estructurar una navegación e interfaz que faciliten las ventas.</p>
          </div>
        </div>

        <!-- Pillar 2 -->
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center text-blue-600 shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-slate-950 text-base mb-1">Comunicación Transparente</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Sin intermediarios ni tecnicismos confusos. Formas parte de cada etapa de revisión mediante un espacio de colaboración directo y ágil.</p>
          </div>
        </div>

        <!-- Pillar 3 -->
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center text-blue-600 shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-slate-950 text-base mb-1">Código Limpio y a medida</h3>
            <p class="text-sm text-slate-500 leading-relaxed">Evitamos el software sobrecargado y las plantillas pesadas. Tu web cargará al instante y será fácil de gestionar en el futuro.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column: Visual Interactive Communication Mockup -->
    <div class="lg:col-span-6 relative w-full flex justify-center items-center">
      <!-- Ambient light-blue blur -->
      <div class="absolute w-80 h-80 rounded-full bg-emerald-500/5 blur-[90px] -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"></div>
      
      <!-- WhatsApp Mockup -->
      <div class="w-full max-w-md bg-[#efeae2] border border-slate-200 rounded-2xl overflow-hidden shadow-xl flex flex-col h-[420px]">
        
        <!-- WhatsApp Header -->
        <div class="bg-[#008069] text-white px-4 py-3 flex items-center justify-between shadow-sm shrink-0">
          <div class="flex items-center gap-3">
            <!-- Back arrow (mock) -->
            <svg class="w-5 h-5 text-white/90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            <!-- Avatar -->
            <div class="relative">
              <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center text-[#008069] font-bold border border-white/10 overflow-hidden">
                <span class="text-sm">B</span>
              </div>
              <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-500 border-2 border-[#008069] rounded-full"></span>
            </div>
            <!-- Contact info -->
            <div class="flex flex-col">
              <span class="text-sm font-bold leading-tight">Beatriz (Ruvedia)</span>
              <span class="text-[11px] text-white/80 leading-none">En línea</span>
            </div>
          </div>
          <!-- Header Actions -->
          <div class="flex items-center gap-4 text-white/95">
            <svg class="w-5 h-5 cursor-pointer hover:opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <svg class="w-5 h-5 cursor-pointer hover:opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <svg class="w-5 h-5 cursor-pointer hover:opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
            </svg>
          </div>
        </div>

        <!-- Chat Area -->
        <div class="flex-1 overflow-y-auto p-4 space-y-3 bg-[#efeae2] relative">
          <!-- Day Divider -->
          <div class="flex justify-center my-2">
            <span class="bg-white/90 backdrop-blur-sm text-[10px] text-slate-500 px-2 py-0.5 rounded shadow-sm uppercase font-semibold tracking-wide">Hoy</span>
          </div>

          <!-- Client Message (Left) -->
          <div class="flex items-start gap-1 max-w-[85%]">
            <div class="bg-white text-slate-800 text-xs rounded-lg rounded-tl-none p-2.5 shadow-sm relative">
              <p class="leading-normal pr-8">¿Cómo va la velocidad de carga de la página inicial? Es muy importante para nuestras campañas.</p>
              <span class="absolute bottom-1 right-2 text-[9px] text-slate-400">10:14</span>
            </div>
          </div>

          <!-- Beatriz (Right) -->
          <div class="flex items-start gap-1 max-w-[85%] ml-auto justify-end">
            <div class="bg-[#d9fdd3] text-slate-800 text-xs rounded-lg rounded-tr-none p-2.5 shadow-sm relative">
              <p class="leading-normal pr-12">¡Hola! Hemos optimizado el código y las imágenes. El test de rendimiento inicial nos da 99/100 de PageSpeed en móviles. 🚀</p>
              <div class="absolute bottom-1 right-2 flex items-center gap-0.5 text-[9px] text-slate-500">
                <span>10:16</span>
                <!-- Blue double check -->
                <svg class="w-3.5 h-3.5 text-[#53bdeb]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
            </div>
          </div>

          <!-- Client Message 2 (Left) -->
          <div class="flex items-start gap-1 max-w-[85%]">
            <div class="bg-white text-slate-800 text-xs rounded-lg rounded-tl-none p-2.5 shadow-sm relative">
              <p class="leading-normal pr-8 font-medium">¡Espectacular! Queda aprobada la propuesta. El diseño final nos encanta. 🙌</p>
              <span class="absolute bottom-1 right-2 text-[9px] text-slate-400">10:18</span>
            </div>
          </div>
        </div>

        <!-- WhatsApp Input Footer -->
        <div class="bg-[#f0f2f5] p-2 flex items-center gap-2 border-t border-slate-200 shrink-0">
          <!-- Emoji icon -->
          <div class="text-slate-500 hover:text-slate-700 p-1 cursor-pointer" aria-hidden="true">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <!-- Attachment icon -->
          <div class="text-slate-500 hover:text-slate-700 p-1 cursor-pointer" aria-hidden="true">
            <svg class="w-5 h-5 rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
            </svg>
          </div>
          <!-- Text Input -->
          <div class="flex-1 bg-white rounded-lg px-3 py-1.5 text-xs text-slate-400 border border-slate-200 select-none">
            Escribe un mensaje...
          </div>
          <!-- Voice/Send icon -->
          <div class="w-8 h-8 rounded-full bg-[#00a884] flex items-center justify-center text-white shadow-sm shrink-0 cursor-pointer">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </div>

      </div>
    </div>
    
  </div>
</section>
