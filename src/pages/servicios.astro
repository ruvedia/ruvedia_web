---
import Layout from '../layouts/Layout.astro';

// Datos de los servicios detallados
const serviciosDetalle = [
  {
    numero: "01",
    titulo: "Landing Page / One Page",
    oferta: "149€",
    antes: "249€",
    tagline: "Perfecto para campañas de anuncios y captación inmediata de clientes.",
    descripcion: "Diseñamos una página de aterrizaje de sección única enfocada al 100% en convencer a tus visitas de que contacten contigo, te llamen o compren tu producto estrella. Es la solución ideal para autónomos y profesionales que lanzan campañas de publicidad en Google Ads, Instagram o Facebook.",
    entregables: [
      "Diseño a medida de sección única de alto impacto",
      "Estructura optimizada",
      "Formulario de contacto y llamadas a la acción directas",
      "Optimización móvil total para reservas o llamadas rápidas",
      "Instalación de píxeles de seguimiento (Google/Meta)",
      "Despliegue ultra rápido"
    ],
    mockupColor: "bg-blue-50 border-blue-100",
    badgeColor: "bg-blue-50 text-blue-700 border-blue-100",
    btnColor: "bg-blue-600 hover:bg-blue-500",
    idLink: "servicios-btn-landing"
  },
  {
    numero: "02",
    titulo: "Web Corporativa Profesional",
    oferta: "299€",
    antes: "499€",
    tagline: "La opción más popular para pymes y marcas referentes.",
    descripcion: "Creamos un sitio web completo de hasta 5 páginas internas para presentar tu negocio, tus servicios al detalle y tu equipo de manera impecable. Con una maquetación moderna, una velocidad de carga de primer nivel y toda la estructura optimizada para que tus clientes confíen en ti.",
    entregables: [
      "Hasta 5 páginas internas (Inicio, Nosotros, Servicios, Blog, Contacto)",
      "Diseño visual único adaptado a tu identidad corporativa",
      "Panel de administración autogestionable de forma segura",
      "SEO técnico on-page (indexación correcta en Google)",
      "Blog integrado para publicar artículos y novedades",
      "Entregado y publicado en 15 días laborables"
    ],
    mockupColor: "bg-indigo-50 border-indigo-100",
    badgeColor: "bg-indigo-50 text-indigo-700 border-indigo-100",
    btnColor: "bg-indigo-600 hover:bg-indigo-500",
    idLink: "servicios-btn-corporativa"
  },
  {
    numero: "03",
    titulo: "Tienda Online / E-commerce",
    oferta: "599€",
    antes: "799€",
    tagline: "Empieza a vender tus productos físicos o digitales con total seguridad.",
    descripcion: "Desarrollamos una plataforma de comercio electrónico rápida y fácil de gestionar. Optimizamos el proceso de compra (checkout en un paso) para evitar carritos abandonados e integramos pasarelas de pago seguras para que cobres al instante y sin complicaciones.",
    entregables: [
      "Catálogo dinámico autogestionable con categorías e imágenes",
      "Proceso de compra optimizado (Checkout rápido)",
      "Integración de pasarelas seguras (Stripe, PayPal, Shopify, Tarjeta)",
      "Gestión simplificada de stock, pedidos y cupones de descuento",
      "Cumplimiento legal completo de comercio electrónico",
      "Formación para gestionar tu catálogo"
    ],
    mockupColor: "bg-emerald-50 border-emerald-100",
    badgeColor: "bg-emerald-50 text-emerald-700 border-emerald-100",
    btnColor: "bg-emerald-600 hover:bg-emerald-500",
    idLink: "servicios-btn-tienda"
  }
];

// Preguntas Frecuentes
const faqs = [
  {
    pregunta: "¿Cuánto tiempo tardará en estar lista mi página web?",
    respuesta: "Nuestros plazos de entrega son rápidos y garantizados por contrato. Una Landing Page suele estar lista en 5 a 7 días laborables, mientras que una Web Corporativa o Tienda Online se entrega en un plazo medio de 15 a 20 días laborables desde la recepción del contenido."
  },
  {
    pregunta: "¿Tengo que pagar alguna mensualidad o cuota de mantenimiento?",
    respuesta: "No, en absoluto. Con Ruvedia pagas únicamente por el desarrollo del proyecto. Una vez entregada, la web es 100% de tu propiedad. Además, el alojamiento básico y la seguridad SSL que configuramos a través de Cloudflare son gratuitos para siempre. No obstante, existen planes mensuales de mantenimiento para tener actualizaciones, copias de seguridad o añadir nuevas funcionalidades."
  },
  {
    pregunta: "¿Cómo se realiza el pago del proyecto?",
    respuesta: "Para tu total seguridad y flexibilidad, ofrecemos dos modalidades de pago. La primera consiste en abonar el 100% del proyecto al finalizar el desarrollo, una vez que estés completamente conforme con el resultado. La segunda es una cómoda opción de pago dividido en cuotas mensuales de hasta un año, facilitando la inversión sin afectar a la liquidez de tu negocio."
  },
  {
    pregunta: "¿Podré modificar los contenidos de mi web por mi cuenta?",
    respuesta: "Sí. Diseñamos nuestras webs corporativas y e-commerce con un sistema de gestión autogestionable extremadamente intuitivo. Te enseñamos a cambiar textos, imágenes o publicar entradas en el blog tú mismo, sin necesidad de tener conocimientos de programación a través del cms de Keystatic"
  },
  {
    pregunta: "¿Por qué utilizáis Cloudflare para el alojamiento?",
    respuesta: "Cloudflare es el estándar global en seguridad y velocidad. Al alojar tu web en su red perimetral, los archivos de tu página se replican en más de 300 servidores en todo el mundo. Esto hace que tu web cargue a la velocidad del rayo en cualquier parte y esté protegida contra hackeos y ataques cibernéticos de forma gratuita."
  }
];
---

<Layout title="Servicios Web Premium | Ruvedia">
  
  <!-- Hero Section -->
  <section class="relative pt-36 pb-20 overflow-hidden bg-white">
    <!-- Grid decorative background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] pointer-events-none z-0" aria-hidden="true"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-100 mb-6 shadow-sm">
        Nuestras Especialidades
      </span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-950 mb-6 leading-tight max-w-4xl mx-auto">
        Servicios web diseñados para <span class="bg-gradient-to-r from-blue-600 via-indigo-600 to-indigo-500 bg-clip-text text-transparent">impulsar tu negocio</span>
      </h1>
      <p class="text-base sm:text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">
        Desarrollamos soluciones digitales personalizadas. Nos centramos en tres pilares fundamentales: código ultra rápido, diseño visual prémium y estructura enfocada en la venta.
      </p>
    </div>
  </section>

  <!-- Detailed Services Section (Alternating Grid Layout) -->
  <section class="py-16 bg-white relative">
    <div class="max-w-7xl mx-auto px-6 space-y-28">
      {serviciosDetalle.map((servicio, idx) => (
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          
          <!-- Text Content Column -->
          <div class={`lg:col-span-6 space-y-6 ${idx % 2 === 1 ? 'lg:order-last' : ''}`}>
            <div class="flex items-center gap-3">
              <span class={`px-2.5 py-0.5 rounded text-[10px] font-bold border uppercase tracking-wider ${servicio.badgeColor}`}>
                Plan {servicio.numero}
              </span>
            </div>
            
            <div class="space-y-3">
              <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-950 leading-tight">
                {servicio.titulo}
              </h2>
              <div class="flex items-baseline gap-2">
                <span class="text-sm font-bold text-slate-400">OFERTA:</span>
                <span class="text-lg text-slate-400 line-through">antes {servicio.antes}</span>
                <span class="text-3xl font-extrabold text-slate-950">desde {servicio.oferta}</span>
              </div>
              <p class="text-lg font-bold text-blue-600">
                {servicio.tagline}
              </p>
            </div>

            <p class="text-base text-slate-600 leading-relaxed font-sans">
              {servicio.descripcion}
            </p>

            <!-- Deliverables Checklist -->
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-2">
              {servicio.entregables.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-blue-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="pt-4">
              <a
                href="/contacto"
                id={servicio.idLink}
                class={`inline-flex items-center justify-center px-6 py-3 rounded-full text-xs font-bold text-white shadow-md transition-all duration-300 ${servicio.btnColor}`}
              >
                Solicitar este Servicio
                <svg class="w-3.5 h-3.5 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Visual Showcase Mockup Column -->
          <div class="lg:col-span-6">
            <div class={`rounded-3xl border p-4 sm:p-6 shadow-inner min-h-[300px] flex items-center justify-center relative overflow-hidden ${servicio.mockupColor}`}>
              <div class="absolute inset-0 opacity-[0.02] pointer-events-none bg-[radial-gradient(#000_1px,transparent_1px)] [background-size:16px_16px]"></div>
              
              <!-- Clean Browser Mockup -->
              <div class="bg-white rounded-2xl border border-slate-200 shadow-lg w-full overflow-hidden">
                <div class="h-8 bg-slate-50 border-b border-slate-200/80 px-3 flex items-center gap-1.5" aria-hidden="true">
                  <span class="w-2.5 h-2.5 rounded-full bg-slate-200"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-slate-200"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-slate-200"></span>
                  <div class="mx-auto w-32 h-4 rounded bg-slate-200/50 text-[8px] text-slate-400 flex items-center justify-center font-mono">ruvedia.com</div>
                </div>
                <!-- Main Image Preview -->
                <div class="overflow-hidden aspect-video relative bg-slate-50">
                  <img 
                    src={servicio.numero === "01" ? "/portfolio/fisioterapia.png" : (servicio.numero === "02" ? "/portfolio/corporativa.png" : "/portfolio/tienda.png")}
                    alt={`Demostración visual de ${servicio.titulo}`}
                    class="w-full h-full object-cover object-top hover:scale-[1.03] transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          </div>

        </div>
      ))}
    </div>
  </section>

  <!-- Performance & Technical Stack Section (Full width highlight) -->
  <section class="py-20 bg-slate-50 relative overflow-hidden border-t border-slate-100">
    <div class="absolute bottom-0 right-0 w-96 h-96 rounded-full bg-blue-500/5 blur-[120px] pointer-events-none z-0" aria-hidden="true"></div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mb-12">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-100 mb-6 shadow-sm">
          Alojamiento & Seguridad
        </span>
        <h2 class="text-3xl font-extrabold text-slate-950 mb-4 leading-tight">
          Velocidad extrema y protección en la red de Cloudflare
        </h2>
        <p class="text-base text-slate-600 leading-relaxed max-w-2xl">
          No sirve de nada tener un diseño bonito si tu página tarda más de 3 segundos en cargar o es vulnerable. Por eso, en todos nuestros desarrollos implementamos los estándares de seguridad y optimización más exigentes del sector.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl border border-slate-200/60 p-6 shadow-sm space-y-3">
          <div class="w-9 h-9 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100 font-bold text-sm" aria-hidden="true">⚡</div>
          <h3 class="text-sm font-extrabold text-slate-900">Cloudflare CDN Global</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Tu página web se replica en más de 300 servidores globales de Cloudflare. Esto reduce la latencia a menos de 15ms y garantiza que tu web cargue de inmediato en cualquier país.
          </p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200/60 p-6 shadow-sm space-y-3">
          <div class="w-9 h-9 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100 font-bold text-sm" aria-hidden="true">🔒</div>
          <h3 class="text-sm font-extrabold text-slate-900">Seguridad SSL y Anti-DDoS</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Certificado SSL obligatorio HTTPS gratuito y protección anti-ataques para mantener tu web siempre activa y segura ante hackeos y tráfico sospechoso.
          </p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200/60 p-6 shadow-sm space-y-3">
          <div class="w-9 h-9 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100 font-bold text-sm" aria-hidden="true">📈</div>
          <h3 class="text-sm font-extrabold text-slate-900">Velocidad PageSpeed 99+</h3>
          <p class="text-sm text-slate-500 leading-relaxed">
            Código limpio sin sobrecarga. Esto reduce el peso de la página, mejora la experiencia móvil del cliente y te ayuda a posicionarte mejor y pagar menos en anuncios de Google Ads.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs Accordion Section -->
  <section class="py-24 bg-white relative border-t border-slate-100">
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      
      <!-- Section Header -->
      <div class="text-center max-w-3xl mb-16 mx-auto">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold bg-blue-50 text-blue-700 border border-blue-100 mb-6 shadow-sm">
          Preguntas Frecuentes
        </span>
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-950 mb-6 leading-tight">
          Resolvemos tus dudas
        </h2>
        <p class="text-lg text-slate-600 leading-relaxed max-w-2xl mx-auto">
          ¿Tienes preguntas sobre el proceso, el alojamiento o el soporte? Aquí respondemos a las consultas más habituales de nuestros clientes.
        </p>
      </div>

      <!-- Accordion Grid -->
      <div class="space-y-4">
        {faqs.map((faq, index) => (
          <details 
            class="group bg-slate-50 border border-slate-200/60 rounded-2xl p-5 [&_summary::-webkit-details-marker]:hidden transition-all duration-300 hover:bg-white hover:shadow-md hover:border-slate-200"
            id={`faq-item-${index}`}
          >
            <summary class="flex justify-between items-center font-bold text-slate-900 text-lg cursor-pointer select-none">
              <span>{faq.pregunta}</span>
              <span class="transition-transform duration-300 group-open:rotate-180 shrink-0 text-slate-400 ml-4" aria-hidden="true">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <p class="text-sm text-slate-500 leading-relaxed pt-3 border-t border-slate-200/60 mt-3 font-sans">
              {faq.respuesta}
            </p>
          </details>
        ))}
      </div>

    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="py-20 bg-slate-950 text-white relative overflow-hidden border-t border-slate-900">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px]"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center space-y-8">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">¿Listo para despegar en internet?</h2>
      <p class="text-sm text-slate-400 leading-relaxed max-w-xl mx-auto">
        Comienza a captar clientes reales con una web optimizada y de diseño premium. Contacta con nosotros y hablemos de tu proyecto sin compromiso.
      </p>
      <div>
        <a
          href="/contacto"
          id="services-final-cta-btn"
          class="inline-flex items-center justify-center px-8 py-3.5 rounded-full text-xs font-bold text-slate-950 bg-white hover:bg-slate-100 hover:shadow-xl hover:shadow-white/5 transition-all duration-300"
        >
          Solicitar Presupuesto Gratis
        </a>
      </div>
    </div>
  </section>

</Layout>
