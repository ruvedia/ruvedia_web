<!-- Client Side script for interactive filtering, device preview, and tabs -->
<script is:inline>
  (function() {
    // 1. FILTERING Lógica
    const filterButtons = document.querySelectorAll(".filtro-btn");
    const projectRows = document.querySelectorAll(".proyecto-row");

    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.getAttribute("data-filter");

        // Cambiar clases activas del filtro
        filterButtons.forEach((b) => {
          b.classList.remove("bg-slate-950", "border-slate-950", "text-white", "shadow-lg", "shadow-slate-950/10");
          b.classList.add("bg-slate-50", "border-slate-200/80", "text-slate-600");
        });
        btn.classList.add("bg-slate-950", "border-slate-950", "text-white", "shadow-lg", "shadow-slate-950/10");
        btn.classList.remove("bg-slate-50", "border-slate-200/80", "text-slate-600");

        // Mostrar u ocultar filas
        projectRows.forEach((row) => {
          const rowTag = row.getAttribute("data-tag");
          if (filter === "todos" || rowTag === filter) {
            row.classList.remove("hidden");
            row.style.opacity = "0";
            row.style.transform = "translateY(12px)";
            setTimeout(() => {
              row.style.opacity = "1";
              row.style.transform = "translateY(0)";
            }, 60);
          } else {
            row.classList.add("hidden");
          }
        });
      });
    });

    // 2. DEVICE PREVIEW SIMULATOR Lógica
    const deviceButtons = document.querySelectorAll(".toggle-device-btn");
    deviceButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const device = btn.getAttribute("data-device");
        const projectId = btn.getAttribute("data-project");
        
        // Contenedores del proyecto específico
        const desktopContainer = document.getElementById(`device-desktop-${projectId}`);
        const mobileContainer = document.getElementById(`device-mobile-${projectId}`);
        
        // Todos los botones del proyecto específico
        const siblings = btn.parentNode.querySelectorAll(".toggle-device-btn");
        siblings.forEach((sib) => {
          sib.classList.remove("bg-white", "text-slate-950", "shadow-sm");
          sib.classList.add("text-slate-500");
        });
        btn.classList.add("bg-white", "text-slate-950", "shadow-sm");
        btn.classList.remove("text-slate-500");

        if (device === "desktop") {
          desktopContainer.classList.remove("hidden");
          mobileContainer.classList.add("hidden");
        } else {
          desktopContainer.classList.add("hidden");
          mobileContainer.classList.remove("hidden");
        }
      });
    });

    // 3. TABS Lógica
    const tabButtons = document.querySelectorAll(".tab-btn");
    tabButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetTab = btn.getAttribute("data-tab");
        const projectId = btn.getAttribute("data-project");
        
        // Elementos del proyecto específico
        const projectRow = btn.closest(".proyecto-row");
        const tabs = projectRow.querySelectorAll(".tab-btn");
        const contents = projectRow.querySelectorAll(".tab-content");

        // Cambiar clases del header de pestañas
        tabs.forEach((tab) => {
          tab.classList.remove("border-blue-600", "text-blue-600");
          tab.classList.add("border-transparent", "text-slate-500");
        });
        btn.classList.add("border-blue-600", "text-blue-600");
        btn.classList.remove("border-transparent", "text-slate-500");

        // Cambiar visibilidad de contenidos
        contents.forEach((content) => {
          content.classList.add("hidden");
        });
        
        const activeContent = document.getElementById(`tab-content-${targetTab}-${projectId}`);
        if (activeContent) {
          activeContent.classList.remove("hidden");
        }
      });
    });
  })();
</script>

